# =============================================================================
# ShadowSync - Git Ignore
# =============================================================================

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
build/
**/build/

# -----------------------------------------------------------------------------
# Flutter / Dart
# -----------------------------------------------------------------------------
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
**/doc/api/
**/ios/Flutter/.last_build_id
**/macos/build/
**/macos/build/.last_build_id

# -----------------------------------------------------------------------------
# IDEs e editores
# -----------------------------------------------------------------------------
.idea/
.vscode/
.cursor/
*.iml
*.ipr
*.iws
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Sistema operacional
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Outros
# -----------------------------------------------------------------------------
*.class
*.log
*.pyc
.history
.svn/
.swiftpm/
migrate_working_dir/
.atom/
.build/
.buildlog/

# -----------------------------------------------------------------------------
# Symbolication / Obfuscation
# -----------------------------------------------------------------------------
app.*.symbols
app.*.map.json

# -----------------------------------------------------------------------------
# Android
# -----------------------------------------------------------------------------
/android/app/debug
/android/app/profile
/android/app/release
/android/.gradle/
/android/local.properties
/android/key.properties
*.jks
*.keystore

# -----------------------------------------------------------------------------
# iOS / macOS
# -----------------------------------------------------------------------------
/ios/Pods/
/ios/.symlinks/
/ios/Flutter/Flutter.framework
/ios/Flutter/Flutter.podspec
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/ServiceDefinitions.json
**/macos/Flutter/ephemeral/
**/xcuserdata/

# -----------------------------------------------------------------------------
# Cobertura de testes
# -----------------------------------------------------------------------------
/coverage/

# -----------------------------------------------------------------------------
# Variáveis de ambiente e secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
